SQLALCHEMY_DATABASE_URI=mysql+pymysql://<username>:<password>@localhost:3306/<db_name>

JWT_SECRET_KEY=<jwt_secret_key>

SERPAPI_KEY=<serp_api_key>

CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=collection
TOK_K_RESULTS=15

LLM_API_KEY=<your_llm_provider_api_key>
LLM_MODEL=<llm_model>
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

WEB_SEARCH_MAX_RESULTS=5
CODE_EXEC_TIMEOUT=10

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TIMEOUT=1500

AWS_ACCESS_KEY_ID=<aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<aws_secret_access_key>
AWS_REGION=<aws_s3_bucket_region>
AWS_S3_BUCKET=<aws_s3_bucket_name>

FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True